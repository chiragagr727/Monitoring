# ============================================================
# NeevCloud Monitoring Platform - Environment Configuration
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production

# --- JWT Secret (CHANGE THIS to a long random string in production) ---
JWT_SECRET=neevcloud-super-secret-change-me-in-production-please-use-64-chars-min
JWT_EXPIRY=7d

# --- Zabbix API Configuration ---
ZABBIX_URL=http://103.192.199.53
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=zabbix

# Zabbix Server (the IP that agents will connect TO)
# This is the public IP/hostname of your Zabbix server reachable by client servers
ZABBIX_SERVER_IP=103.192.199.53
ZABBIX_SERVER_PORT=10051

# --- Default Templates to use when adding hosts (Zabbix template names) ---
# Common: "Linux by Zabbix agent", "Linux by Zabbix agent active", "Windows by Zabbix agent"
DEFAULT_LINUX_TEMPLATE=Linux by Zabbix agent
DEFAULT_LINUX_ACTIVE_TEMPLATE=Linux by Zabbix agent active
DEFAULT_WINDOWS_TEMPLATE=Windows by Zabbix agent

# --- Default Host Group for client hosts (will be created if missing) ---
DEFAULT_HOST_GROUP=NeevCloud Clients

# --- Database ---
DB_PATH=./data/neevcloud.db
